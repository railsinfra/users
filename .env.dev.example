# Users service (dev)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
SERVER_ADDR=0.0.0.0:8080
ACCOUNTS_GRPC_URL=http://localhost:50052
RUST_LOG=info
ENVIRONMENT=development
FRONTEND_BASE_URL=http://localhost:5173
# Required at startup (no insecure defaults). Use long random values, e.g. openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32
API_KEY_HASH_SECRET=change_me_different_from_jwt_secret
SENTRY_DSN=

# Resend (password reset, beta notifications)
RESEND_API_KEY=re_your_dev_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Rails Financial Infrastructure
RESEND_BASE_URL=https://api.resend.com
RESEND_BETA_NOTIFICATION_EMAIL=beta@yourdomain.com
