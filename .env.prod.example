# Users service (prod)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
SERVER_ADDR=0.0.0.0:8080
ACCOUNTS_GRPC_URL=https://accounts-service-production.up.railway.app
RUST_LOG=info
ENVIRONMENT=production
FRONTEND_BASE_URL=https://rails-web-production.up.railway.app
JWT_SECRET=change_me_use_strong_random_secret
API_KEY_HASH_SECRET=change_me_different_from_jwt
INTERNAL_SERVICE_TOKEN_ALLOWLIST=change_me_comma_separated_tokens
SENTRY_DSN=

# Resend (password reset, beta notifications)
RESEND_API_KEY=re_your_production_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Rails Financial Infrastructure
RESEND_BASE_URL=https://api.resend.com
RESEND_BETA_NOTIFICATION_EMAIL=beta@yourdomain.com
